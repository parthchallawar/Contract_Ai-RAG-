# Copy this file to .env and fill in your own key. Never commit .env.
# cp .env.example .env   (macOS/Linux)   |   copy .env.example .env   (Windows)

# Required — get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-your-key-here"

# Optional — override the default model. The default is a free model with a
# per-day rate limit (50 requests/day as of writing) and noticeably flakier
# JSON/structured output than a paid model. For anything beyond a quick demo,
# a small paid model (e.g. a Claude Haiku, GPT-4o-mini, or Gemini Flash tier
# on OpenRouter) will be both more reliable and still inexpensive.
# OPENROUTER_MODEL=nemotron-3-nano-30b-a3b:free
# OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# Optional fallback provider — NVIDIA NIM (get a free key at build.nvidia.com,
# key format nvapi-...). Used automatically ONLY when OpenRouter fails before
# producing any content (e.g. daily rate limit hit) — OpenRouter is always
# tried first. Both vars must be set for the fallback to activate; leave both
# unset to run OpenRouter-only (the original single-provider behavior).
# NIM_API_KEY=nvapi-your-key-here
# NIM_MODEL=meta/llama-3.1-8b-instruct

# Optional — change the server port (default 8080)
# PORT=8080
